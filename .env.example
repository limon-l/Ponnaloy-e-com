# ═══════════════════════════════════════════════════════════
# Ponnaloy E-Commerce — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Never commit .env to version control (already in .gitignore).
#
# For Vercel: Set these in Project Settings > Environment Variables.
# ═══════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────
# NODE_ENV is set automatically by Next.js (development for `next dev`, production for `next build`)
# Do NOT set NODE_ENV in .env — it causes build failures on Vercel
PORT=3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# ─── MongoDB ──────────────────────────────────────────────
# Local:       mongodb://localhost:27017/ponnaloy
# Atlas:       mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/ponnaloy

# ─── Session Secret ───────────────────────────────────────
# Used for signing session cookies. Generate a strong random string for production.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-here

# ─── Clerk Auth (new architecture) ────────────────────────
# CLERK_SECRET_KEY=sk_test_
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
# CLERK_WEBHOOK_SECRET=whsec_

# ─── Stripe ───────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_
# STRIPE_WEBHOOK_SECRET=whsec_
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# ─── Redis (new architecture) ─────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Meilisearch (new architecture) ───────────────────────
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=ponnaloy_master_key

# ─── Cloudflare R2 / S3 (new architecture) ────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=ponnaloy
# R2_PUBLIC_URL=

# ─── OpenAI (optional — AI concierge) ─────────────────────
# OPENAI_API_KEY=sk-your-key-here
