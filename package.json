{
  "name": "ponnaloy-e-com",
  "version": "2.0.0",
  "private": true,
  "description": "Premium B2C e-commerce platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build --filter=@ponnaloy/web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @ponnaloy/api db:generate",
    "db:push": "pnpm --filter @ponnaloy/api db:push",
    "db:migrate": "pnpm --filter @ponnaloy/api db:migrate",
    "db:seed": "pnpm --filter @ponnaloy/api db:seed",
    "db:studio": "pnpm --filter @ponnaloy/api db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
