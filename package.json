{
  "name": "ponnaloy-e-com",
  "version": "1.0.0",
  "description": "Premium e-commerce storefront with Express and SQLite",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./public/input.css -o ./public/styles.css --minify",
    "watch:css": "tailwindcss -i ./public/input.css -o ./public/styles.css --watch"
  },
  "keywords": [
    "e-commerce",
    "express",
    "sqlite",
    "storefront"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-sqlite3": "^0.9.16",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "gsap": "^3.15.0",
    "helmet": "^8.1.0",
    "lucide": "^1.23.0",
    "morgan": "^1.10.0",
    "motion": "^12.42.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.2",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19"
  }
}
